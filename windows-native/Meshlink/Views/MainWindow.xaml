<Window x:Class="Meshlink.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meshlink" Width="900" Height="650"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: room list -->
        <Grid Grid.Column="0" Background="{StaticResource SurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,0">
                <TextBlock Text="Meshlink" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnSearch" Content="🔍" FontSize="16" Background="Transparent"
                            Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand"
                            Width="36" Height="36" Click="BtnSearch_Click"/>
                    <Button x:Name="btnNewChat" Content="✏️" FontSize="16" Background="Transparent"
                            Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" Cursor="Hand"
                            Width="36" Height="36" Click="BtnNewChat_Click"/>
                    <Button x:Name="btnProfile" Content="👤" FontSize="16" Background="Transparent"
                            Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand"
                            Width="36" Height="36" Click="BtnProfile_Click"/>
                </StackPanel>
            </Grid>

            <!-- Search -->
            <TextBox x:Name="tbSearch" Grid.Row="1" Style="{StaticResource DarkTextBox}"
                     Margin="12,4" Tag="Search chats..." TextChanged="TbSearch_TextChanged"/>

            <!-- Room list -->
            <ListBox x:Name="lbRooms" Grid.Row="2" Style="{StaticResource DarkListBox}"
                     SelectionChanged="LbRooms_SelectionChanged" Margin="4,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,6" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Avatar -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#2D1B69">
                                <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="Bold"
                                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Name + last message -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}"
                                           FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding LastMessage}" Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Time -->
                            <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" Foreground="{StaticResource MutedBrush}"
                                       FontSize="10" VerticalAlignment="Top" Margin="0,4,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Bottom nav -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="💬" FontSize="18" Width="50" Height="40" Background="Transparent"
                        Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🎬" FontSize="18" Width="50" Height="40" Background="Transparent"
                        Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand" Click="BtnShorts_Click"/>
                <Button Content="🎵" FontSize="18" Width="50" Height="40" Background="Transparent"
                        Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand" Click="BtnMusic_Click"/>
                <Button Content="🛒" FontSize="18" Width="50" Height="40" Background="Transparent"
                        Foreground="{StaticResource MutedBrush}" BorderThickness="0" Cursor="Hand" Click="BtnMarket_Click"/>
            </StackPanel>
        </Grid>

        <!-- Right panel: chat view -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Chat header -->
            <Grid Grid.Row="0" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,1">
                <TextBlock x:Name="tbChatTitle" Text="Select a chat" FontSize="17" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="20,0"/>
            </Grid>

            <!-- Messages -->
            <ListBox x:Name="lbMessages" Grid.Row="1" Style="{StaticResource DarkListBox}" Margin="8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SenderName}" Foreground="{StaticResource PrimaryBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TimeDisplay}" Foreground="{StaticResource MutedBrush}"
                                           FontSize="10" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Body}" Foreground="{StaticResource TextBrush}"
                                       FontSize="14" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Input -->
            <Grid Grid.Row="2" Background="{StaticResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="tbMessage" Grid.Column="0" Style="{StaticResource DarkTextBox}"
                         Margin="8,8" Tag="Message..." KeyDown="TbMessage_KeyDown"/>
                <Button x:Name="btnSend" Grid.Column="1" Content="➤" FontSize="18"
                        Style="{StaticResource PrimaryButton}" Width="44" Height="36" Margin="0,8,8,8"
                        Click="BtnSend_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
